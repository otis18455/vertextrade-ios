name: Build iOS IPA

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-13
    
    steps:
    - name: Checkout
      uses: actions/checkout@v4
    
    - name: Setup Xcode
      uses: maxim-lobanov/setup-xcode@v1
      with:
        xcode-version: '15.0'
    
    - name: Check Project Structure
      run: |
        echo "Current directory:"
        pwd
        echo "Contents:"
        ls -la
        echo "VertexTrade folder:"
        ls -la VertexTrade/
        echo "Xcode project:"
        ls -la VertexTrade.xcodeproj/
    
    - name: Create Export Options
      run: |
        mkdir -p build
        cat > build/ExportOptions.plist << 'EOF'
        <?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
        <plist version="1.0">
        <dict>
            <key>method</key>
            <string>development</string>
            <key>signingStyle</key>
            <string>manual</string>
            <key>stripSwiftSymbols</key>
            <true/>
            <key>compileBitcode</key>
            <false/>
        </dict>
        </plist>
        EOF
        cat build/ExportOptions.plist
    
    - name: Build Archive
      run: |
        cd "${{ github.workspace }}"
        xcodebuild clean archive \
          -project VertexTrade.xcodeproj \
          -scheme VertexTrade \
          -destination 'generic/platform=iOS' \
          -archivePath "${{ github.workspace }}/build/VertexTrade.xcarchive" \
          CODE_SIGN_IDENTITY="" \
          CODE_SIGNING_REQUIRED=NO \
          CODE_SIGNING_ALLOWED=NO \
          | tee build/build.log
      continue-on-error: true
    
    - name: Check Build Status
      run: |
        if [ -d "${{ github.workspace }}/build/VertexTrade.xcarchive" ]; then
          echo "Build succeeded!"
          ls -la "${{ github.workspace }}/build/VertexTrade.xcarchive"
        else
          echo "Build failed! Showing last 50 lines of log:"
          tail -50 "${{ github.workspace }}/build/build.log"
          exit 1
        fi
    
    - name: Export IPA
      run: |
        cd "${{ github.workspace }}"
        xcodebuild -exportArchive \
          -archivePath "${{ github.workspace }}/build/VertexTrade.xcarchive" \
          -exportPath "${{ github.workspace }}/build/output" \
          -exportOptionsPlist "${{ github.workspace }}/build/ExportOptions.plist" \
          CODE_SIGN_IDENTITY="" \
          CODE_SIGNING_REQUIRED=NO \
          CODE_SIGNING_ALLOWED=NO
    
    - name: Check Output
      run: |
        echo "Build output:"
        ls -la "${{ github.workspace }}/build/output/"
    
    - name: Rename IPA
      run: |
        cd "${{ github.workspace }}/build/output"
        for f in *.ipa; do
          mv "$f" "VertexTrade.ipa"
          break
        done
        ls -la
    
    - name: Upload IPA Artifact
      uses: actions/upload-artifact@v4
      with:
        name: VertexTrade-IPA
        path: ${{ github.workspace }}/build/output/VertexTrade.ipa
        retention-days: 30
    
    - name: Upload Build Log
      uses: actions/upload-artifact@v4
      if: failure()
      with:
        name: Build-Log
        path: ${{ github.workspace }}/build/build.log
